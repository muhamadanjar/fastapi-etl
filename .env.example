# API
DEBUG=True
SECRET_KEY=your-secret-key-here
PORT=8000
# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/etl_db
USERMANAGEMENT_API_URL=http://localhost:8070
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_CACHE_TTL_DEFAULT=3600
REDIS_CACHE_MAX_CONNECTIONS=50
# Cache Namespaces
CACHE_NAMESPACE_JOBS=jobs
CACHE_NAMESPACE_FILES=files
CACHE_NAMESPACE_METRICS=metrics
# Background
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:63791/0
UPLOAD_CHUNK_SIZE=10240

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_JSON_FORMAT=False
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
