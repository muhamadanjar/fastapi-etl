[Unit]
Description=FastAPI app with Gunicorn + UvicornWorker
After=network.target
[Service]
User=root
Group=www-data
WorkingDirectory=/var/www/fastapi-etl
EnvironmentFile=/var/www/fastapi-etl/.env
ExecStart=/var/www/fastapi-etl/venv/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker app.main:app --bind 0.0.0.0:8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target